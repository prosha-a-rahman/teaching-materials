# import libraries
import numpy as np
import matplotlib.pyplot as plt
n = 10
u = np.random.rand(n)
y = max(u) # compute their maxmium
print(u, "\n")
print("The sorted sequence of uniform random variables is \n", np.sort(u),"\n")
print("The maximum of our observed random variables is \n", y)
